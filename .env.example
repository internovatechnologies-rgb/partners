# Partner-application email delivery via Zoho Mail (SMTP).
# Copy to .env.local for local dev, and set the same values in Vercel
# (Project → Settings → Environment Variables) for production.
#
# If ZOHO_SMTP_USER / ZOHO_SMTP_PASS are unset, the form still works: the
# submission is logged server-side and reported as success (nothing is lost).

# Required to actually send email:
ZOHO_SMTP_USER=partners@yourdomain.com          # your Zoho mailbox
ZOHO_SMTP_PASS=your-app-specific-password        # accounts.zoho.com → Security → App Passwords

# Optional:
PARTNER_INBOX=partners@yourdomain.com            # where applications land (defaults to ZOHO_SMTP_USER)
PARTNER_FROM=Theraptly Partners <partners@yourdomain.com>  # From line (defaults to ZOHO_SMTP_USER)
ZOHO_SMTP_HOST=smtp.zoho.com                     # global region default
ZOHO_SMTP_PORT=465                               # 465 = SSL; use 587 for STARTTLS
